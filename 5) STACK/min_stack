class Minstack :
    def __init__(self):
        self.stack = []
        self.minstack = []
              
    def push(self , val) :
        self.stack.append(val)
        
        
        if not self.minstack :
            self.minstack.append(val)         
        else :    
            current_min = min(val , self.minstack[-1])
            self.minstack.append(current_min)        
             
    def pop(self):
        self.stack.pop()
        self.minstack.pop()    
            
    def top(self):
        return self.stack[-1]  
    
    def getmin(self):
        return self.minstack[-1]
        
        
obj = Minstack()

obj.push(5)
obj.push(2)
obj.push(4)

obj.getmin()

obj.pop()
obj.getmin()

obj.pop()
obj.getmin()
